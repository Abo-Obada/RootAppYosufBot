{
  "compilerOptions": {
    "target": "es2020",
    "composite": true,
    "declaration": true,
    "outDir": "dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "sourceMap": false,
    "allowJs": false,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "rootDir": "src"
  },
  "include": ["src/**/*.ts", "src/json/badWorldList.json", "src/images/**/*.png"],
  "exclude": ["node_modules"]
}
